{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@glee/types": ["packages/types/src/index.ts"],
      "@glee/api": ["packages/api/src/index.ts"],
      "@glee/ui": ["packages/ui/src/index.ts"],
      "@glee/utils": ["packages/utils/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
